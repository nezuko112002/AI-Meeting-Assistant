# Copy this to .env.local — never commit .env.local to git

# OpenAI — GPT-4o suggestions
OPENAI_API_KEY=sk-your-openai-api-key-here

# AssemblyAI — transcription + speaker diarization
# Get a free key at https://assemblyai.com
ASSEMBLYAI_API_KEY=your-assemblyai-api-key-here

# ─────────────────────────────────────
# Google Sheets Integration
# ─────────────────────────────────────
# Setup steps:
# 1. Go to console.cloud.google.com
# 2. Create a project → Enable Google Sheets API
# 3. IAM & Admin → Service Accounts → Create Service Account
# 4. Create a JSON key → download it
# 5. Copy client_email and private_key from the JSON file
# 6. Share ALL sheets with the service account email (Editor access)
